{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "tests/**",
      "package.json",
      "package-lock.json",
      "README.md",
      "**/*.example.js"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
